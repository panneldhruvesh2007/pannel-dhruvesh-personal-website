# ============================================================
# PANNEL DHRUVESH — PORTFOLIO BACKEND ENVIRONMENT VARIABLES
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values below
# 3. NEVER commit .env to Git — it's already in .gitignore
# ============================================================


# ── SUPABASE ─────────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-secret-key


# ── SMTP EMAIL NOTIFICATIONS (optional) ──────────────────────
# Used to send you an email when someone submits the contact form.
# If left empty, email notifications are silently skipped.
#
# Gmail setup:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to: Google Account → Security → App Passwords
#   3. Generate a password for "Mail" and paste it as SMTP_PASS
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
NOTIFY_EMAIL=your@gmail.com


# ── CORS ALLOWED ORIGINS ─────────────────────────────────────
# Comma-separated list of frontend URLs allowed to call this API.
#
# Rules:
#   - Must start with http:// or https://
#   - No trailing slashes
#   - No spaces around commas
#
# Local development origins are included by default in config.py.
# Add your deployed frontend URL here for production:
#
ALLOWED_ORIGINS=http://localhost:5500,http://localhost:3000,https://your-site.vercel.app
