# ── CORS ALLOWED ORIGINS ──────────────────────────────────
# Comma-separated list of frontend URLs allowed to call this API.
# Rules:
#   - Must start with http:// or https://
#   - No trailing slashes
#   - No spaces around commas
#
# Development (already included as defaults — no need to set):
#   http://localhost:5500, http://localhost:3000, http://localhost:8080
#
# Production — add your deployed frontend URL:
#   https://panneldhruvesh.netlify.app
#   https://panneldhruvesh.vercel.app
#   https://yourdomain.com
#
ALLOWED_ORIGINS=http://localhost:5500,http://localhost:3000,https://your-frontend.vercel.app
